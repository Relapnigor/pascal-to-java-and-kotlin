start: program

program: "program" NAME ";" program_block "."

program_block: var_section? (function_decl | procedure_decl)* block

%import .declarations (function_decl, procedure_decl)
%import .var_section (var_section)
%import .blocks (block)
%import .tokens (NAME, COMMENT1, COMMENT2)

%import common.WS
%ignore WS
%ignore COMMENT1
%ignore COMMENT2